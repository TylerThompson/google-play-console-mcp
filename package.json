{
  "name": "mcp-google-play-console",
  "version": "1.0.0",
  "description": "MCP server for Google Play Console analytics and reporting",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "verify:permissions": "tsx scripts/verify-play-permissions.ts"
  },
  "keywords": [
    "mcp",
    "google-play",
    "analytics",
    "reporting"
  ],
  "author": "Tyler Thompson",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "googleapis": "^144.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
